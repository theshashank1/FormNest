# =============================================================================
# FormNest — Environment Variables
# Copy to .env and fill in your values
# =============================================================================

# --- Server ---
ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8001
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:8001

# --- Database (PostgreSQL) ---
# Option 1: Full connection URL (preferred)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/formnest_dev
# Option 2: Individual components (assembled automatically if DATABASE_URL is empty)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=formnest_dev

# Database pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
# Set to true for managed cloud databases (Neon, Supabase, Azure PostgreSQL, etc.)
# Leave false (default) for local development with a plain PostgreSQL container.
DB_REQUIRE_SSL=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# --- Supabase (shared with TREEEX-WBSP — same project) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key
SUPABASE_WEBHOOK_SECRET=your-webhook-secret

# --- Security ---
SECRET_KEY=change-me-in-production-use-a-random-32-char-string

# --- Email (Resend.com) ---
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@formnest.in

# --- Spam Protection ---
HCAPTCHA_SECRET=your-hcaptcha-secret-key

# --- Cloudflare R2 (Media Storage) ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=formnest-media
R2_PUBLIC_URL=https://cdn.formnest.in

# --- Monitoring ---
SENTRY_DSN=
LOGFIRE_TOKEN=

# --- Development Tunnel (optional) ---
DEVTUNNEL_NAME=formnest-webhook
DEVTUNNEL_URL=
